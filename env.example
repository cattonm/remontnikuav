# Приклад оточення для remontnikuav. Скопіюй у .env і заповни.
# У проді (Render) ці ж змінні задаються в Dashboard -> Environment.
# Файл .env у git НЕ потрапляє (див. .gitignore).

# --- Обов'язкові ---
BOT_TOKEN=                 # токен від @BotFather
# WEBHOOK_SECRET обов'язковий у проді (коли задано RENDER_EXTERNAL_URL).
# Згенеруй довгий випадковий рядок, напр.: python -c "import secrets;print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=
# Окремий секрет для підпису сесій веб-кабінету (НЕ дорівнює BOT_TOKEN).
# Згенеруй так само, іншим значенням.
SESSION_SECRET=

# --- Google Sheets (поточне сховище) ---
GOOGLE_CREDS_JSON=         # весь JSON сервіс-акаунта одним рядком

# --- Опційне ---
GEMINI_API_KEY=            # для генерації звітів; без нього ця фіча вимкнена
# RENDER_EXTERNAL_URL задає сам Render автоматично у проді.
# Локально лишай порожнім — тоді CORS дозволить localhost і WEBHOOK_SECRET не обов'язковий.
RENDER_EXTERNAL_URL=

# --- Сховище (Етап 3) ---
# sheets (за замовчуванням) або postgres.
STORAGE_BACKEND=sheets
# Потрібен ЛИШЕ при STORAGE_BACKEND=postgres. Бери в Supabase ->
# Project Settings -> Database -> Connection string (URI).
# Радимо pooler (порт 6543).
DATABASE_URL=

# --- Прайс (Етап A) ---
# Джерело цін перемикається ОКРЕМО від заявок:
#   sheets   (за замовчуванням) — аркуш «Ціни» в Google-таблиці;
#   postgres                    — таблиця prices у БД + редактор у кабінеті.
# Порядок переходу:
#   1) python migrate.py up        (створює таблицю)
#   2) python import_prices.py     (заливає поточні ціни)
#   3) python import_prices.py --check   (звірка)
#   4) виставити PRICES_BACKEND=postgres і перезапустити сервіс
PRICES_BACKEND=sheets

# Номер тенанта, від імені якого працює цей інстанс. До Етапу B — завжди 1.
TENANT_ID=1

# --- Авторизація (Етап A) ---
# Джерело користувачів та інвайтів:
#   sheets   (за замовчуванням) — аркуші «Admins» і «Invites» у Google-таблиці;
#   postgres                    — таблиці users та invites у БД.
# Порядок переходу:
#   1) python migrate.py up      (створює users/invites)
#   2) python import_users.py    (або --from-csv admins.csv, якщо Google не відповідає)
#   3) python import_users.py --check
#   4) виставити AUTH_BACKEND=postgres і перезапустити сервіс
# ПІСЛЯ ЦЬОГО GOOGLE БІЛЬШЕ НЕ ПОТРІБЕН ДЛЯ ВХОДУ В КАБІНЕТ.
AUTH_BACKEND=sheets

# Telegram id власника. Заходить у кабінет завжди — навіть якщо база
# недоступна. Це аварійний вхід, тому значення тримаємо в оточенні.
MASTER_ADMIN_ID=845232133
